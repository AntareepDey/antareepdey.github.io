---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SocialLinks from "../components/SocialLinks.astro";
import ResearchItem from "../components/ResearchItem.astro";
import NewsItem from "../components/NewsItem.astro";
import "../styles/global.css";

import publications from "../data/publications.json";
import news from "../data/news.json";

// Sort by date descending and get top items
const sortedPublications = [...publications].sort(
	(a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
const recentPublications = sortedPublications.slice(0, 3);

const sortedNews = [...news].sort(
	(a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);
const recentNews = sortedNews.slice(0, 5);
---

<BaseLayout title="Antareep Dey">
	<Navbar currentPath="/" />

	<main class="container">
		<!-- Hero Section -->
		<section class="hero" id="hero">
			<img
				src="/profile.avif"
				alt="Antareep Dey profile photo"
				class="profile-img"
				width="140"
				height="140"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>

			<div class="hero-content">
				<h1 class="hero-title">Antareep Dey</h1>
				<p class="tagline">/un·tuh·rip dey/</p>
				<span class="role mono">Student Researcher</span>

				<SocialLinks />
			</div>
		</section>

		<!-- About Section -->
		<section id="about">
			<h2 class="section-heading">About Me :</h2>
			<div class="about-text">
				<p>
					I'm a Student Researcher at <a href="https://www.iitkgp.ac.in/" class="link-highlight">IIT Kharagpur</a>, working on computer vision with a focus on video understanding, test-time adaptation, and vision-language multimodality. I'm especially interested in the capabilities that emerge from the unique interactions between vision and language, capabilities neither modality can achieve on its own, and understanding what drives that emergence is what keeps me curious. Previously, I've also worked on explainable AI for medical imaging, small language models, and edge-deployed vision systems.
				</p>
				<p>
					In my free time, you'll find me obsessing over <a href="https://www.mercedesamgf1.com/" class="link-highlight">Formula 1</a> 🏎️ ,marvelling at architecture 🏛️, or feeding my inner <a href="/gallery" class="link-highlight">shutterbug</a>📸. I firmly believe the best
					ideas come from conversations, preferably caffeinated ones ☕.
					If you're interested in my research ( and even if you aren't ) <a href="mailto:antareep2018@gmail.com" class="link-highlight">let's connect!</a> 💬
				</p>
			</div>
		</section>

		<!-- Recent Research -->
		<section id="research">
			<h2 class="section-heading">Recent Research</h2>

			{
				recentPublications.map((pub) => (
					<ResearchItem
						title={pub.title}
						authors={pub.authors}
						venue={pub.venue}
						year={pub.year}
						paperUrl={pub.paperUrl}
						codeUrl={pub.codeUrl}
					/>
				))
			}

			<a href="/publications" class="view-all mono">View All →</a>
		</section>

		<!-- News -->
		<section id="news">
			<h2 class="section-heading">News</h2>
			<ul class="news-list">
				{
					recentNews.map((item) => (
						<NewsItem
							date={item.displayDate}
							content={item.content}
						/>
					))
				}
			</ul>

			<a href="/news" class="view-all mono">View All→</a>
		</section>
	</main>

	<Footer />
</BaseLayout>
