---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Personal Website of Antareep Dey.",
  image = "/profile.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

import "@fontsource-variable/newsreader";
import "@fontsource/dm-mono/300.css";
import "@fontsource/dm-mono/400.css";
import "@fontsource/dm-mono/500.css";
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <ClientRouter />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Optimized Font Loading -->
    <!-- Fonts are imported directly in the Astro frontmatter for self-hosting -->

    <!-- KaTeX CSS for math rendering is now deferred to the end of body for better performance -->

    <!-- Prevent FOUC (Flash of Unstyled Content) for theme -->
    <script is:inline>
      const restoreTheme = () => {
        const storedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const theme = storedTheme || (prefersDark ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      };

      restoreTheme();

      document.addEventListener("astro:after-swap", restoreTheme);
    </script>
  </head>
  <body>
    <slot />

    <!-- Theme & Navigation Scripts -->
    <script is:inline>
      // Hydrate state on page load/transition
      const syncNavbarAndThemeState = () => {
        const html = document.documentElement;
        const themeSwitch = document.getElementById("theme-switch");
        if (themeSwitch) {
          themeSwitch.checked = html.getAttribute("data-theme") === "dark";
        }
        const navbar = document.getElementById("navbar");
        if (navbar) {
          navbar.classList.toggle("scrolled", window.scrollY > 10);
        }
      };

      // Attach event listeners exactly once globally using Event Delegation
      if (!window.hasGlobalLayoutListeners) {
        // Enable transitions on the theme switch container on first user interaction
        const enableThemeSwitchTransition = (e) => {
          const container = e.target.closest(".switch-container.no-transition");
          if (container) {
            container.classList.remove("no-transition");
          }
        };
        document.addEventListener("pointerover", enableThemeSwitchTransition);
        document.addEventListener("pointerdown", enableThemeSwitchTransition);
        document.addEventListener("focusin", enableThemeSwitchTransition);

        // Theme Toggle Delegation
        document.addEventListener("change", (e) => {
          if (e.target && e.target.id === "theme-switch") {
            const isDark = e.target.checked;
            const newTheme = isDark ? "dark" : "light";
            document.documentElement.setAttribute("data-theme", newTheme);
            localStorage.setItem("theme", newTheme);
          }
        });

        // Mobile Menu & Document Click Logic
        document.addEventListener("click", (e) => {
          const hamburger = document.getElementById("hamburger-btn");
          const mobileMenu = document.getElementById("mobile-menu");
          
          if (hamburger && hamburger.contains(e.target)) {
            e.stopPropagation();
            mobileMenu?.classList.toggle("active");
          } else if (
            mobileMenu &&
            mobileMenu.classList.contains("active") &&
            !mobileMenu.contains(e.target)
          ) {
            mobileMenu.classList.remove("active");
          }
        });

        // Scroll Event delegation
        window.addEventListener("scroll", () => {
          const navbar = document.getElementById("navbar");
          if (navbar) {
            navbar.classList.toggle("scrolled", window.scrollY > 10);
          }
        });

        window.hasGlobalLayoutListeners = true;
      }

      document.addEventListener("DOMContentLoaded", syncNavbarAndThemeState);
      document.addEventListener("astro:page-load", syncNavbarAndThemeState);
    </script>
    <!-- Deferred KaTeX Loading - Only loads if math elements are present -->
    <script is:inline>
      const loadKatex = () => {
        if (
          (document.querySelector(".katex") ||
            document.querySelector(".math")) &&
          !document.getElementById("katex-css")
        ) {
          const link = document.createElement("link");
          link.id = "katex-css";
          link.rel = "stylesheet";
          link.href =
            "https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css";
          link.integrity =
            "sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV";
          link.crossOrigin = "anonymous";
          document.head.appendChild(link);
        }
      };
      // Run on initial load and potentially subsequent navigations
      window.addEventListener("load", loadKatex);
      document.addEventListener("astro:page-load", loadKatex);
    </script>
  </body>
</html>
