---
interface Props {
    category: string;
    items: { title: string; url: string }[];
    size?: "large" | "medium" | "small";
}

const { category, items, size = "medium" } = Astro.props;

// Show first 6 items, with "more" indicator if there are more
const maxVisible = 6;
const visibleItems = items.slice(0, maxVisible);
const remainingCount = items.length - maxVisible;
---

<div class={`misc-card misc-card--${size}`}>
    <h3 class="misc-card-title">{category}</h3>
    <ul class="misc-card-list">
        {
            visibleItems.map((item) => (
                <li>
                    <a
                        href={item.url}
                        class="misc-link"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {item.title}
                        <span class="misc-link-arrow">↗</span>
                    </a>
                </li>
            ))
        }
        {
            remainingCount > 0 && (
                <li class="misc-more">and {remainingCount} more...</li>
            )
        }
    </ul>
</div>
